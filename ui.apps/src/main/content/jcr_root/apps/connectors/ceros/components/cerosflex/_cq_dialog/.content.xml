<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0" xmlns:granite="http://www.adobe.com/jcr/granite/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
    jcr:primaryType="nt:unstructured"
    jcr:title="Properties"
    sling:resourceType="cq/gui/components/authoring/dialog"
    extraClientlibs="[ceros.cerosflex.authoring]">
    <content
        jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns">
        <items jcr:primaryType="nt:unstructured">
            <column
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/container">
                <items jcr:primaryType="nt:unstructured">

                    <cerosMode
                        granite:class="cq-dialog-dropdown-showhide"
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/coral/foundation/form/select"
                        fieldLabel="Delivery Mode"
                        fieldDescription="Server-side (Always Fetch): loads manifest on every page render. Server-side (Store): fetches once and saves to JCR. Client-side (Iframe embed): injects the Ceros embed script for client-side rendering."
                        name="./cerosMode">
                        <granite:data
                            jcr:primaryType="nt:unstructured"
                            cq-dialog-dropdown-showhide-target=".cerosflex-mode-toggle"/>
                        <items jcr:primaryType="nt:unstructured">
                            <fetch
                                jcr:primaryType="nt:unstructured"
                                text="Server-side (Always Fetch)"
                                value="fetch"
                                selected="{Boolean}true"/>
                            <store
                                jcr:primaryType="nt:unstructured"
                                text="Server-side (Store)"
                                value="store"/>
                            <embed
                                jcr:primaryType="nt:unstructured"
                                text="Client-side (Iframe embed)"
                                value="embed"/>
                        </items>
                    </cerosMode>

                    <manifestUrl
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                        fieldLabel="Ceros Experience URL"
                        fieldDescription="Paste the full https:// URL to the published Ceros experience"
                        pattern="^https://[^\s/]+(?::\d+)?/.+$"
                        name="./manifestUrl"/>

                    <lastFetched
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                        disabled="{Boolean}true"
                        fieldLabel="Last Fetched"
                        name="./cerosPrefetchedAt"/>

                    <embedSection
                        granite:class="cerosflex-mode-toggle hidden"
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/coral/foundation/container">
                        <granite:data
                            jcr:primaryType="nt:unstructured"
                            showhidetargetvalue="embed"/>
                        <items jcr:primaryType="nt:unstructured">
                            <cerosEmbedType
                                granite:class="cq-dialog-dropdown-showhide"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                fieldLabel="Iframe Type"
                                fieldDescription="Full Height: iframe auto-resizes to the experience content (no inner scrollbars). Scrolling: iframe stays at a fixed height and the experience scrolls inside it."
                                name="./cerosEmbedType">
                                <granite:data
                                    jcr:primaryType="nt:unstructured"
                                    cq-dialog-dropdown-showhide-target=".cerosflex-embed-type-toggle"/>
                                <items jcr:primaryType="nt:unstructured">
                                    <fullheight
                                        jcr:primaryType="nt:unstructured"
                                        text="Full Height"
                                        value="fullheight"
                                        selected="{Boolean}true"/>
                                    <scrolling
                                        jcr:primaryType="nt:unstructured"
                                        text="Scrolling"
                                        value="scrolling"/>
                                </items>
                            </cerosEmbedType>

                            <embedHeightSection
                                granite:class="cerosflex-embed-type-toggle hidden"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/container">
                                <granite:data
                                    jcr:primaryType="nt:unstructured"
                                    showhidetargetvalue="scrolling"/>
                                <items jcr:primaryType="nt:unstructured">
                                    <cerosEmbedHeight
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                        fieldLabel="Iframe Height"
                                        fieldDescription="CSS length, e.g. 800px or 75vh."
                                        name="./cerosEmbedHeight"
                                        value="800px"/>
                                </items>
                            </embedHeightSection>
                        </items>
                    </embedSection>

                </items>
            </column>
        </items>
    </content>
</jcr:root>
