<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
    jcr:primaryType="nt:unstructured"
    jcr:title="Properties"
    sling:resourceType="cq/gui/components/authoring/dialog"
    extraClientlibs="[ceros.cerosflex.authoring]">
    <content
        jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns">
        <items jcr:primaryType="nt:unstructured">
            <column
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/container">
                <items jcr:primaryType="nt:unstructured">

                    <cerosMode
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/coral/foundation/form/select"
                        fieldLabel="Delivery Mode"
                        fieldDescription="Server-side (Always Fetch): loads manifest on every page render. Server-side (Store): fetches once and saves to JCR. Client-side (Iframe embed): injects the Ceros embed script for client-side rendering."
                        name="./cerosMode">
                        <items jcr:primaryType="nt:unstructured">
                            <fetch
                                jcr:primaryType="nt:unstructured"
                                text="Server-side (Always Fetch)"
                                value="fetch"
                                selected="{Boolean}true"/>
                            <store
                                jcr:primaryType="nt:unstructured"
                                text="Server-side (Store)"
                                value="store"/>
                            <embed
                                jcr:primaryType="nt:unstructured"
                                text="Client-side (Iframe embed)"
                                value="embed"/>
                        </items>
                    </cerosMode>

                    <manifestUrl
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                        fieldLabel="Ceros Experience URL"
                        fieldDescription="Paste the full https:// URL to the published Ceros experience"
                        pattern="^https://[^\s/]+(?::\d+)?/.+$"
                        name="./manifestUrl"/>

                    <lastFetched
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                        disabled="{Boolean}true"
                        fieldLabel="Last Fetched"
                        name="./cerosPrefetchedAt"/>

                    <cerosEmbedType
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/coral/foundation/form/select"
                        fieldLabel="Iframe Type"
                        fieldDescription="Only applies in Client-side (Iframe embed) mode. Full Height: iframe auto-resizes to the experience content (no inner scrollbars). Scrolling: iframe stays at a fixed height and the experience scrolls inside it."
                        name="./cerosEmbedType">
                        <items jcr:primaryType="nt:unstructured">
                            <fullheight
                                jcr:primaryType="nt:unstructured"
                                text="Full Height"
                                value="fullheight"
                                selected="{Boolean}true"/>
                            <scrolling
                                jcr:primaryType="nt:unstructured"
                                text="Scrolling"
                                value="scrolling"/>
                        </items>
                    </cerosEmbedType>

                    <cerosEmbedHeight
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                        fieldLabel="Iframe Height"
                        fieldDescription="Used only when Iframe Type is Scrolling. CSS length, e.g. 800px or 75vh."
                        name="./cerosEmbedHeight"
                        value="800px"/>

                </items>
            </column>
        </items>
    </content>
</jcr:root>
